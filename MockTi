    function processDeposit() {
        const amount = parseFloat(document.getElementById('depositAmount')?.value);
        if(amount && amount > 0) {
            userData.walletBalance += amount;
            userData.totalEarned += amount;
            transactions.unshift({
                id: Date.now(),
                type: 'receive',
                amount: amount,
                description: 'Deposit via ' + (document.getElementById('depositMethod')?.value || 'Bank'),
                date: new Date().toLocaleDateString()
            });
            updateDashboard();
            showToast(`✅ $${amount} deposited successfully!`);
            closeAllModals();
        } else {
            showToast('Please enter a valid amount', true);
        }
    }

    function processWithdraw() {
        const amount = parseFloat(document.getElementById('withdrawAmount')?.value);
        if(amount && amount > 0 && amount <= userData.walletBalance) {
            userData.walletBalance -= amount;
            transactions.unshift({
                id: Date.now(),
                type: 'send',
                amount: amount,
                description: 'Withdrawal to ' + (document.getElementById('withdrawMethod')?.value || 'Bank'),
                date: new Date().toLocaleDateString()
            });
            updateDashboard();
            showToast(`✅ $${amount} withdrawn successfully!`);
            closeAllModals();
        } else {
            showToast(`Invalid amount. Max: $${userData.walletBalance.toFixed(2)}`, true);
        }
    }

    function switchPage(pageId) {
        if(!currentUser && (pageId === 'dashboard' || pageId === 'wallet')) {
            showToast('Please login to access this page', true);
            openLoginModal();
            return;
        }
        
        document.querySelectorAll('.page').forEach(page => page.classList.remove('active-page'));
        document.getElementById(`${pageId}-page`).classList.add('active-page');
        document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
        const activeLink = document.querySelector(`.nav-link[data-page="${pageId}"]`);
        if(activeLink) activeLink.classList.add('active');
        
        if(pageId === 'dashboard' || pageId === 'wallet') updateDashboard();
        if(pageId === 'jobs') renderJobs();
        if(pageId === 'freelancers') renderFreelancers();
        
        window.scrollTo(0, 0);
    }

    function closeAllModals() {
        document.getElementById('modalOverlay').classList.remove('active');
    }

    function closeModal(e) {
        if(e.target === document.getElementById('modalOverlay')) {
            closeAllModals();
        }
    }

    // Check for saved user on load
    const savedUser = localStorage.getItem('mockti_user');
    if(savedUser) {
        currentUser = JSON.parse(savedUser);
    }

    // Initialize
    renderAuthSection();
    renderCategories();
    renderJobs();
    renderFreelancers();
    updateDashboard();
</script>
</body>
</html>
