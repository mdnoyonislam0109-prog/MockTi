        const newUser = { name, email, password, country, role: selectedRole };
        localStorage.setItem('mockti_user', JSON.stringify(newUser));
        currentUser = newUser;
        renderAuthSection();
        closeAllModals();
        showToast(`🎉 Welcome to MockTi, ${name}! Your account has been created.`);
        switchPage('dashboard');
