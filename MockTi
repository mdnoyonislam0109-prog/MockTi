<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>MockTi - World's Smartest Freelancing Marketplace</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6C63FF;
            --primary-dark: #4a43c9;
            --secondary: #FF6584;
            --accent: #00D9FF;
            --dark: #0A0A0F;
            --card: #12121A;
            --card-light: #1A1A28;
            --border: #252530;
            --text: #E4E4E7;
            --muted: #A1A1B0;
            --success: #00C853;
            --warning: #FFD600;
            --danger: #FF1744;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--dark);
            color: var(--text);
            overflow-x: hidden;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1A1A24;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 10px;
        }

        .glass {
            background: rgba(20, 20, 30, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(108, 99, 255, 0.15);
        }

        .gradient-text {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 14px rgba(108, 99, 255, 0.3);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(108, 99, 255, 0.4);
        }

        .btn-outline {
            background: transparent;
            border: 1.5px solid rgba(108, 99, 255, 0.6);
            padding: 12px 28px;
            border-radius: 40px;
            font-weight: 500;
            color: var(--text);
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            border-color: var(--primary);
            background: rgba(108, 99, 255, 0.1);
        }

        .btn-sm {
            padding: 8px 20px;
            font-size: 14px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 30px;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            flex-wrap: wrap;
            gap: 20px;
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 10, 15, 0.95);
            backdrop-filter: blur(10px);
        }

        .logo {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }
        .logo i {
            color: var(--primary);
        }

        .nav-links {
            display: flex;
            gap: 35px;
            align-items: center;
            flex-wrap: wrap;
        }
        .nav-links a {
            text-decoration: none;
            color: #C1C2D0;
            font-weight: 500;
            transition: 0.2s;
            cursor: pointer;
        }
        .nav-links a:hover, .nav-links a.active {
            color: var(--primary);
        }

        .auth-buttons {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .user-menu {
            position: relative;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
        }
        .user-avatar:hover {
            transform: scale(1.05);
        }
        .user-name {
            color: var(--text);
            font-weight: 500;
        }
        .logout-btn {
            background: rgba(255, 23, 68, 0.2);
            border: 1px solid var(--danger);
            padding: 6px 12px;
            border-radius: 20px;
            color: var(--danger);
            cursor: pointer;
            font-size: 12px;
            transition: 0.3s;
        }
        .logout-btn:hover {
            background: var(--danger);
            color: white;
        }

        .wallet-indicator {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(0, 217, 255, 0.1);
            border: 1px solid rgba(0, 217, 255, 0.3);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 14px;
        }
        .wallet-indicator:hover {
            background: rgba(0, 217, 255, 0.2);
        }

        .page {
            display: none;
            animation: fadeIn 0.4s ease;
        }
        .active-page {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero {
            padding: 80px 0 100px;
            text-align: center;
        }
        .hero h1 {
            font-size: 64px;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 24px;
        }

        .search-bar {
            background: #181822;
            border-radius: 60px;
            padding: 8px 8px 8px 24px;
            display: flex;
            align-items: center;
            max-width: 700px;
            margin: 40px auto 0;
            border: 1px solid #2D2D3A;
        }
        .search-bar input {
            background: transparent;
            border: none;
            padding: 16px 0;
            font-size: 16px;
            width: 100%;
            color: white;
            outline: none;
        }
        .search-bar button {
            background: var(--primary);
            border: none;
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            color: white;
        }

        .section-title {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 48px;
            text-align: center;
        }

        .category-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 80px;
        }
        .category-card {
            background: var(--card);
            padding: 24px;
            border-radius: 28px;
            border: 1px solid var(--border);
            transition: 0.25s;
            cursor: pointer;
        }
        .category-card:hover {
            transform: translateY(-8px);
            border-color: var(--primary);
            box-shadow: 0 10px 30px rgba(108, 99, 255, 0.2);
        }
        .category-card i {
            font-size: 38px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 20px;
        }

        .jobs-grid, .freelancers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .job-card, .freelancer-card {
            background: var(--card);
            border-radius: 24px;
            padding: 24px;
            border: 1px solid var(--border);
            transition: 0.3s;
        }
        .job-card:hover, .freelancer-card:hover {
            border-color: var(--primary);
            transform: translateY(-5px);
        }

        .badge {
            background: rgba(108, 99, 255, 0.2);
            color: var(--primary);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .skill-tags {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin: 12px 0;
        }
        .skill-tag {
            background: rgba(108, 99, 255, 0.1);
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
        }

        .dashboard-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }
        .stat-card {
            background: var(--card);
            padding: 24px;
            border-radius: 28px;
            text-align: center;
            border: 1px solid var(--border);
        }
        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--primary);
            margin: 10px 0;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(5px);
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal {
            background: var(--card);
            border-radius: 32px;
            padding: 40px;
            max-width: 500px;
            width: 90%;
            border: 1px solid var(--border);
            animation: modalPop 0.3s ease;
        }
        .modal.large {
            max-width: 700px;
        }
        @keyframes modalPop {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }
        .close-btn {
            background: none;
            border: none;
            color: var(--muted);
            font-size: 28px;
            cursor: pointer;
            transition: 0.3s;
        }
        .close-btn:hover {
            color: var(--text);
        }

        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--muted);
            font-size: 14px;
            font-weight: 500;
        }
        .form-group input, .form-group textarea, .form-group select {
            width: 100%;
            padding: 14px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: var(--text);
            font-family: inherit;
            font-size: 14px;
            transition: 0.3s;
        }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .role-selector {
            display: flex;
            gap: 15px;
            margin-bottom: 25px;
        }
        .role-option {
            flex: 1;
            padding: 15px;
            background: rgba(255,255,255,0.03);
            border: 2px solid var(--border);
            border-radius: 16px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }
        .role-option.selected {
            border-color: var(--primary);
            background: rgba(108, 99, 255, 0.1);
        }
        .role-option i {
            font-size: 28px;
            margin-bottom: 8px;
            display: block;
        }

        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #1A1A2E;
            border-left: 4px solid var(--primary);
            padding: 16px 24px;
            border-radius: 16px;
            z-index: 2000;
            animation: slideIn 0.3s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .features {
            background: #0E0E14;
            border-radius: 48px;
            padding: 64px 40px;
            margin: 60px 0;
        }
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 40px;
        }
        .feature-card {
            text-align: center;
            padding: 20px;
        }
        .feature-icon {
            width: 80px;
            height: 80px;
            background: rgba(108, 99, 255, 0.1);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 36px;
            transition: 0.3s;
        }
        .feature-card:hover .feature-icon {
            background: var(--primary);
            transform: rotateY(360deg);
        }

        .stats {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 30px;
            background: linear-gradient(145deg, #0F0F18, var(--dark));
            border-radius: 48px;
            padding: 50px 40px;
            text-align: center;
        }
        .stat-number {
            font-size: 44px;
            font-weight: 800;
            color: var(--primary);
        }

        footer {
            border-top: 1px solid #1F1F2A;
            padding: 48px 0 32px;
            margin-top: 80px;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 40px; }
            .container { padding: 0 20px; }
            .nav-links { gap: 15px; justify-content: center; }
            .footer-grid { grid-template-columns: 1fr; }
            .auth-buttons { order: -1; width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

<div class="container">
    <nav class="navbar">
        <div class="logo" onclick="switchPage('home')">
            <i class="fas fa-rocket"></i>
            <span class="gradient-text">MockTi</span>
        </div>
        <div class="nav-links" id="navLinks">
            <a class="nav-link active" data-page="home">Home</a>
            <a class="nav-link" data-page="jobs">Find Work</a>
            <a class="nav-link" data-page="freelancers">Freelancers</a>
            <a class="nav-link" data-page="dashboard">Dashboard</a>
            <a class="nav-link" data-page="wallet">Wallet</a>
        </div>
        <div id="authSection">
            <!-- Auth buttons will be injected here -->
        </div>
    </nav>

    <!-- HOME PAGE -->
    <div id="home-page" class="page active-page">
        <div class="hero" data-aos="fade-up">
            <span class="glass" style="display: inline-block; padding: 6px 18px; border-radius: 40px; font-size: 14px; margin-bottom: 24px;">
                ✨ World's Smartest AI-Powered Marketplace
            </span>
            <h1>Find the Best Talent,<br><span class="gradient-text">Global Connection</span></h1>
            <p style="font-size: 18px; color: var(--muted); max-width: 600px; margin: 0 auto;">
                AI Skill Mapper, Blockchain Reputation, Real-time Translation in 100+ Languages
            </p>
            <div class="search-bar">
                <input type="text" id="homeSearch" placeholder="Search any skill... (e.g., Web Developer, SEO, AI Expert)">
                <button onclick="searchJobs()"><i class="fas fa-search"></i> Search</button>
            </div>
        </div>

        <h2 class="section-title" data-aos="fade-right">📂 Browse Categories</h2>
        <div class="category-grid" id="categoryGrid"></div>

        <div class="features" data-aos="fade-up">
            <h2 class="section-title">🚀 Platform Features</h2>
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-brain"></i></div>
                    <h3>AI Skill Mapper</h3>
                    <p>5-minute adaptive tests that accurately identify your expertise level</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-globe"></i></div>
                    <h3>Language Bridge</h3>
                    <p>Real-time neural translation supporting 100+ languages</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-link"></i></div>
                    <h3>Blockchain Rep</h3>
                    <p>Immutable reputation scores stored on-chain</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-coins"></i></div>
                    <h3>Global Pay</h3>
                    <p>USD, Crypto, Local methods (bKash, M-Pesa, UPI)</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-file-contract"></i></div>
                    <h3>Smart Contracts</h3>
                    <p>Automated milestone-based payments</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3>Escrow Protection</h3>
                    <p>100% payment protection</p>
                </div>
            </div>
        </div>

        <div class="stats" data-aos="zoom-in">
            <div><div class="stat-number">150k+</div><div>Active Freelancers</div></div>
            <div><div class="stat-number">45k+</div><div>Projects Completed</div></div>
            <div><div class="stat-number">120+</div><div>Countries</div></div>
            <div><div class="stat-number">98%</div><div>Satisfaction</div></div>
        </div>
    </div>

    <!-- JOBS PAGE -->
    <div id="jobs-page" class="page">
        <h2 class="section-title" style="margin-top: 40px;">🔥 Active Projects</h2>
        <div class="search-bar" style="margin-bottom: 30px; max-width: 100%;">
            <input type="text" id="jobSearchInput" placeholder="Search jobs by title, category, or skill...">
            <button onclick="filterJobs()">Search</button>
        </div>
        <div id="jobsList" class="jobs-grid"></div>
    </div>

    <!-- FREELANCERS PAGE -->
    <div id="freelancers-page" class="page">
        <h2 class="section-title" style="margin-top: 40px;">🏆 Top Freelancers</h2>
        <div class="search-bar" style="margin-bottom: 30px; max-width: 100%;">
            <input type="text" id="freelancerSearchInput" placeholder="Search freelancers by name or skill...">
            <button onclick="filterFreelancers()">Search</button>
        </div>
        <div id="freelancersList" class="freelancers-grid"></div>
    </div>

    <!-- DASHBOARD PAGE -->
    <div id="dashboard-page" class="page">
        <h2 class="section-title" style="margin-top: 40px;">📊 Your Dashboard</h2>
        
        <div class="dashboard-stats">
            <div class="stat-card">
                <i class="fas fa-briefcase" style="font-size: 36px; color:var(--primary);"></i>
                <div class="stat-value" id="activeProjects">0</div>
                <h3>Active Projects</h3>
            </div>
            <div class="stat-card">
                <i class="fas fa-dollar-sign" style="font-size: 36px; color:var(--primary);"></i>
                <div class="stat-value" id="totalEarnings">$0</div>
                <h3>Total Earnings</h3>
            </div>
            <div class="stat-card">
                <i class="fas fa-star" style="font-size: 36px; color:var(--primary);"></i>
                <div class="stat-value" id="trustScore">4.9</div>
                <h3>Trust Score</h3>
            </div>
            <div class="stat-card">
                <i class="fas fa-clock" style="font-size: 36px; color:var(--primary);"></i>
                <div class="stat-value" id="completedJobs">0</div>
                <h3>Completed Jobs</h3>
            </div>
        </div>

        <div style="background: var(--card); border-radius: 28px; padding: 32px; text-align: center;">
            <h3>🤖 AI Skill Mapper Recommendation</h3>
            <p style="margin-top: 15px;">Best categories for you: <strong class="gradient-text">UI/UX Design & Web Development</strong></p>
            <button class="btn-primary" style="margin-top: 20px;" onclick="showToast('🎯 AI Skill Assessment started! Answer 10 questions to identify your strengths.')">Take Skill Test</button>
        </div>
        
        <div style="background: var(--card); border-radius: 28px; padding: 32px; margin-top: 30px;">
            <h3><i class="fas fa-tasks"></i> Active Projects</h3>
            <div id="activeProjectsList" style="margin-top: 20px;"></div>
        </div>
    </div>

    <!-- WALLET PAGE -->
    <div id="wallet-page" class="page">
        <h2 class="section-title" style="margin-top: 40px;">💰 Your Wallet</h2>
        <div style="background: var(--card); border-radius: 32px; padding: 40px; border: 1px solid var(--border);">
            <div style="background: linear-gradient(135deg, rgba(108,99,255,0.2), rgba(0,217,255,0.1)); border-radius: 24px; padding: 30px; margin-bottom: 30px;">
                <p style="color: var(--muted);">Available Balance</p>
                <div style="font-size: 48px; font-weight: 800;" id="walletBalance">$0</div>
                <div class="wallet-actions" style="display: flex; gap: 15px; margin-top: 20px;">
                    <button class="btn-primary" onclick="openDepositModal()"><i class="fas fa-arrow-down"></i> Deposit</button>
                    <button class="btn-outline" onclick="openWithdrawModal()"><i class="fas fa-arrow-up"></i> Withdraw</button>
                </div>
            </div>
            
            <h3><i class="fas fa-history"></i> Recent Transactions</h3>
            <div id="transactionList" style="margin-top: 20px;"></div>
        </div>
    </div>

    <footer>
        <div class="footer-grid">
            <div>
                <div class="logo gradient-text" style="font-size: 28px;"><i class="fas fa-rocket"></i> MockTi</div>
                <p style="margin-top: 12px; color: var(--muted);">Borderless Skills Marketplace</p>
            </div>
            <div><h4>Platform</h4><p>Find Work</p><p>Hire Talent</p><p>Enterprise</p></div>
            <div><h4>Resources</h4><p>Help Center</p><p>Blog</p><p>Community</p></div>
            <div><h4>Legal</h4><p>Privacy Policy</p><p>Terms of Service</p><p>Cookie Policy</p></div>
        </div>
        <div style="text-align: center; padding-top: 30px; border-top: 1px solid var(--border); color:var(--muted);">
            © 2025 MockTi – Beyond Borders, Beyond Skills
        </div>
    </footer>
</div>

<!-- Modals -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
    <div class="modal" id="activeModal" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h3 id="modalTitle">Modal Title</h3>
            <button class="close-btn" onclick="closeAllModals()"><i class="fas fa-times"></i></button>
        </div>
        <div id="modalBody"></div>
    </div>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ duration: 800, once: true });

    // =============== COMPLETE SKILLS LIST ===============
    const allSkills = [
        "Web Development", "Mobile Development", "UI/UX Design", "Graphic Design", "Logo Design",
        "SEO", "Social Media Marketing", "Content Writing", "Copywriting", "Video Editing",
